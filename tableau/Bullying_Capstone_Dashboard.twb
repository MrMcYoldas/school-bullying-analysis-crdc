    <worksheet name='Detailed Demographic Heatmap (2)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontsize='20'>Detailed Demographic Heatmap </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='12'>Compare reported bullying impact across student groups and genders.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>📊 Detailed Demographic Heatmap</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>Purpose</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'>Identify demographic bullying hotspots by comparing reported affected students across U.S. states, protected bullying categories, student groups, and gender.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>How to Read</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'>Each </run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>row</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'> represents a U.S. state.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'>Each </run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>column</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'> represents a student subgroup (e.g., Hispanic, Black, IDEA, Section 504) separated by gender.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'>The </run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>Protected Category</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'> filter switches between different bullying categories (currently </run>
            <run bold='true' fontcolor='#000000' fontname='tableau lite' fontsize='12'>Race</run>
            <run fontcolor='#000000' fontname='tableau lite' fontsize='12'> or </run>
