              <lod column='[federated.1qn48001eby5rv1e2lkk00qfeqg5].[sum:discipline_rate_pct:qk]' />
              <lod column='[federated.1qn48001eby5rv1e2lkk00qfeqg5].[sum:difference:qk]' />
              <lod column='[federated.1qn48001eby5rv1e2lkk00qfeqg5].[none:suggested_action:nk]' />
              <text column='[federated.1qn48001eby5rv1e2lkk00qfeqg5].[sum:students_reported_as_affected:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
