  <worksheets>
    <worksheet name='Allegations per School'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>&lt;Sheet Name&gt;</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='12'>Normalized reporting intensity.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='22'>Represents the total number of reported bullying and harassment allegations across the five primary CRDC categories (Sex, Race, Sexual Orientation, Disability, and Religion). This metric reflects reported incidents, not verified individual cases. </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_dashboard_summary (s_yoldaserdem.vw_dashboard_summary) (nf_da_onl_09032026)' name='federated.1ljygyr156ms081gaj5hh1elsuzn' />
          </datasources>
          <datasource-dependencies datasource='federated.1ljygyr156ms081gaj5hh1elsuzn'>
            <column caption='Allegations Per School' datatype='real' name='[allegations_per_school]' role='measure' type='quantitative' />
            <column-instance column='[allegations_per_school]' derivation='Sum' name='[sum:allegations_per_school:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.1ljygyr156ms081gaj5hh1elsuzn].[sum:allegations_per_school:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run fontcolor='#000000' fontname='Tableau Light'>Average number of reported allegation per school.</run>
                <run>Æ&#10;&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Light'>This normalized metric allows fairer comparisons between jurisdictions with different numbers of schools.</run>
              </formatted-text>
            </customized-tooltip>
            <customized-label>
              <formatted-text>
                <run fontsize='48'>&lt;</run>
                <run fontsize='48'>[federated.1ljygyr156ms081gaj5hh1elsuzn].[sum:allegations_per_school:qk]</run>
                <run fontsize='48'>&gt;</run>
              </formatted-text>
            </customized-label>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-cull' value='true' />
                <format attr='mark-labels-show' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows />
