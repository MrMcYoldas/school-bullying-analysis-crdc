    <worksheet name='Detailed Demographic Heatmap'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontsize='20'>Detailed Demographic Heatmap </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='12'>Compare reported bullying impact across student groups and genders.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontname='Tableau Light' fontsize='12'>📄 Demographic Hotspot Heatmap</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontname='Tableau Light' fontsize='12'>Purpose</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Light' fontsize='12'>Shows which student groups are most affected within each state and protected bullying category.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontname='Tableau Light' fontsize='12'>Methodology</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Light' fontsize='12'>Data is reshaped from the CRDC school-level table into a long-format SQL view. Each cell represents one state, student group, and gender combination. The protected category filter allows the user to switch between sex-based and race-based harassment.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontname='Tableau Light' fontsize='12'>Key Insight</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Light' fontsize='12'>Darker cells highlight concentrated reporting volume. This view helps identify whether specific demographic groups drive reporting patterns within high-impact states.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_state_demographic_heatmap (s_yoldaserdem.vw_state_demographic_heatmap) (nf_da_onl_09032026)' name='federated.0x7r86805if2kd14e858b0l4vysj' />
          </datasources>
          <datasource-dependencies datasource='federated.0x7r86805if2kd14e858b0l4vysj'>
            <column-instance column='[protected_category]' derivation='Attribute' name='[attr:protected_category:nk]' pivot='key' type='nominal' />
            <column-instance column='[student_group]' derivation='Attribute' name='[attr:student_group:nk]' pivot='key' type='nominal' />
            <column caption='Display Order' datatype='integer' name='[display_order]' role='measure' type='quantitative' />
            <column caption='Gender' datatype='string' name='[gender]' role='dimension' type='nominal' />
            <column-instance column='[display_order]' derivation='Min' name='[min:display_order:qk]' pivot='key' type='quantitative' />
            <column-instance column='[gender]' derivation='None' name='[none:gender:nk]' pivot='key' type='nominal' />
            <column-instance column='[protected_category]' derivation='None' name='[none:protected_category:nk]' pivot='key' type='nominal' />
            <column-instance column='[state]' derivation='None' name='[none:state:nk]' pivot='key' type='nominal' />
            <column-instance column='[student_group]' derivation='None' name='[none:student_group:nk]' pivot='key' type='nominal' />
            <column caption='Protected Category' datatype='string' name='[protected_category]' role='dimension' type='nominal' />
            <column caption='State' datatype='string' name='[state]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column caption='Student Group' datatype='string' name='[student_group]' role='dimension' type='nominal' />
            <column caption='Students Disciplined' datatype='integer' name='[students_disciplined]' role='measure' type='quantitative' />
            <column caption='Students Reported As Affected' datatype='integer' name='[students_reported_as_affected]' role='measure' type='quantitative' />
            <column-instance column='[students_disciplined]' derivation='Sum' name='[sum:students_disciplined:qk]' pivot='key' type='quantitative' />
            <column-instance column='[students_reported_as_affected]' derivation='Sum' name='[sum:students_reported_as_affected:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0x7r86805if2kd14e858b0l4vysj].[none:protected_category:nk]'>
            <groupfilter function='level-members' level='[none:protected_category:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <computed-sort column='[federated.0x7r86805if2kd14e858b0l4vysj].[none:state:nk]' direction='DESC' using='[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_reported_as_affected:qk]' />
          <computed-sort column='[federated.0x7r86805if2kd14e858b0l4vysj].[none:student_group:nk]' direction='ASC' using='[federated.0x7r86805if2kd14e858b0l4vysj].[min:display_order:qk]' />
          <slices>
            <column>[federated.0x7r86805if2kd14e858b0l4vysj].[none:protected_category:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='width' field='[federated.0x7r86805if2kd14e858b0l4vysj].[none:gender:nk]' value='67' />
          </style-rule>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_reported_as_affected:qk]' max='1000' min='0' palette='Yoldas Blue Sequential' type='interpolated' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Square' />
            <encodings>
              <color column='[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_reported_as_affected:qk]' />
              <tooltip column='[federated.0x7r86805if2kd14e858b0l4vysj].[attr:protected_category:nk]' />
              <tooltip column='[federated.0x7r86805if2kd14e858b0l4vysj].[attr:student_group:nk]' />
              <tooltip column='[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_disciplined:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run bold='true' fontname='Tableau Light'>State</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[none:state:nk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Protected Category</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[attr:protected_category:nk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Student Group</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[none:student_group:nk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Gender</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[none:gender:nk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>────────────────────────</run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Students Reported as Affected</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_reported_as_affected:qk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Students Receiving Disciplinary Action</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_disciplined:qk]>]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Response Gap</run>
                <run>Æ&#10;</run>
                <run bold='true' fontname='Tableau Light'><![CDATA[<[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_reported_as_affected:qk]> reported vs <[federated.0x7r86805if2kd14e858b0l4vysj].[sum:students_disciplined:qk]> disciplined]]></run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>────────────────────────</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Tableau Light'>Insight</run>
                <run>Æ&#10;</run>
                <run fontcolor='#000000' fontname='Tableau Light'>This subgroup represents one of the highest reported affected-student populations within the selected protected category for this state. </run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontname='Tableau Light'>Interpretation</run>
                <run>Æ&#10;</run>
                <run fontname='Tableau Light'>This cell shows the reported impact for this demographic subgroup within the selected protected bullying category</run>
              </formatted-text>
            </customized-tooltip>
