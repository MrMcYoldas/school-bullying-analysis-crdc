    <worksheet name='Students Affected by Protected Group'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontsize='20'>Students Affected by Protected Group</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000'>Comparison of students reported as affected across federally protected student groups.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>📄 Demographic Impact Analysis</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Purpose</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Compares the number of students reported as affected across demographic groups within the federally protected bullying categories collected in the CRDC 2021–2022 dataset. Each bar represents a </run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>protected category and subgroup combination</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'> (e.g., </run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12' italic='true'>Sex – Female</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>, </run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12' italic='true'>Race – Male</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>, </run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12' italic='true'>Disability – Female</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>), rather than a direct comparison between race and sex.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Methodology</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Data is aggregated from the </run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>vw_demographic_summary</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'> SQL view. Student groups are created by combining the protected bullying category with the reported demographic subgroup. Colors indicate the calculated </run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Priority Level</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'> based on the reporting volume for each group.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Key Insight</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>This visualization identifies which demographic subgroups account for the largest number of students reported as affected </run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>within each protected category</run>
            <run fontcolor='#000000' fontname='Tableau Light' fontsize='12'>. It is intended to highlight reporting patterns and support deeper investigation rather than compare different protected categories directly. </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_demographic_summary (s_yoldaserdem.vw_demographic_summary) (nf_da_onl_09032026)' name='federated.1qn48001eby5rv1e2lkk00qfeqg5' />
          </datasources>
          <datasource-dependencies datasource='federated.1qn48001eby5rv1e2lkk00qfeqg5'>
            <column caption='Difference' datatype='integer' name='[difference]' role='measure' type='quantitative' />
            <column caption='Discipline Rate Pct' datatype='real' name='[discipline_rate_pct]' role='measure' type='quantitative' />
            <column-instance column='[priority_level]' derivation='None' name='[none:priority_level:nk]' pivot='key' type='nominal' />
            <column-instance column='[student_group]' derivation='None' name='[none:student_group:nk]' pivot='key' type='nominal' />
            <column-instance column='[suggested_action]' derivation='None' name='[none:suggested_action:nk]' pivot='key' type='nominal' />
            <column caption='Priority Level' datatype='string' name='[priority_level]' role='dimension' type='nominal' />
            <column caption='Student Group' datatype='string' name='[student_group]' role='dimension' type='nominal' />
            <column caption='Students Disciplined' datatype='integer' name='[students_disciplined]' role='measure' type='quantitative' />
            <column caption='Students Reported As Affected' datatype='integer' name='[students_reported_as_affected]' role='measure' type='quantitative' />
            <column caption='Suggested Action' datatype='string' name='[suggested_action]' role='dimension' type='nominal' />
            <column-instance column='[difference]' derivation='Sum' name='[sum:difference:qk]' pivot='key' type='quantitative' />
            <column-instance column='[discipline_rate_pct]' derivation='Sum' name='[sum:discipline_rate_pct:qk]' pivot='key' type='quantitative' />
            <column-instance column='[students_disciplined]' derivation='Sum' name='[sum:students_disciplined:qk]' pivot='key' type='quantitative' />
            <column-instance column='[students_reported_as_affected]' derivation='Sum' name='[sum:students_reported_as_affected:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.1qn48001eby5rv1e2lkk00qfeqg5].[none:student_group:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Sex - Female&quot;</bucket>
              <bucket>&quot;Race - Male&quot;</bucket>
