            <column caption='Total Allegations' datatype='integer' name='[total_allegations]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <computed-sort column='[federated.1yugb3x0j9iwxa19y2sp81daxtfs].[none:allegation_category:nk]' direction='DESC' using='[federated.1yugb3x0j9iwxa19y2sp81daxtfs].[sum:total_allegations:qk]' />
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='title' class='0' field='[federated.1yugb3x0j9iwxa19y2sp81daxtfs].[sum:total_allegations:qk]' scope='cols' value='Reported Allegations' />
