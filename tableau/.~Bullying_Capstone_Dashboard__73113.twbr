    <worksheet name='Top States by Reporting Intensity'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontsize='20'>State Ranking by Normalized Reporting Rate</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='12'>States ranked by reported bullying allegations per school.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>📄 State Ranking</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Purpose</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Ranks states by normalized reporting rate to identify jurisdictions with the highest reported bullying intensity.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Methodology</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>The metric is calculated as total reported allegations divided by the number of school records in each state. This allows fairer comparison between large and small states.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Key Insight</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>This ranking complements the map by showing exact state-level values. Higher values indicate stronger reporting intensity, not automatically worse school performance.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_state_summary (s_yoldaserdem.vw_state_summary) (nf_da_onl_09032026)' name='federated.0odtoq51mrihk71as89e00sy026k' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0odtoq51mrihk71as89e00sy026k'>
            <column caption='Normalized Reporting Rate (per School)' datatype='real' name='[allegations_per_school]' role='measure' type='quantitative' />
            <column caption='Discipline To Allegation Ratio' datatype='real' datatype-customized='true' name='[discipline_to_allegation_ratio]' role='measure' type='quantitative' />
            <column-instance column='[discipline_to_allegation_ratio]' derivation='Min' name='[min:discipline_to_allegation_ratio:ok]' pivot='key' type='ordinal' />
            <column-instance column='[schools_with_allegations]' derivation='Min' name='[min:schools_with_allegations:qk]' pivot='key' type='quantitative' />
            <column-instance column='[students_disciplined]' derivation='Min' name='[min:students_disciplined:qk]' pivot='key' type='quantitative' />
            <column-instance column='[students_reported_as_affected]' derivation='Min' name='[min:students_reported_as_affected:qk]' pivot='key' type='quantitative' />
            <column-instance column='[total_main_allegations]' derivation='Min' name='[min:total_main_allegations:qk]' pivot='key' type='quantitative' />
            <column-instance column='[priority_level]' derivation='None' name='[none:priority_level:nk]' pivot='key' type='nominal' />
